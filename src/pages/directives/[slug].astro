---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { llmLabel, categorySlug, STATUS_LABEL } from '../../lib/format';
import type { QuestionEntry } from '../../../scripts/extract-questions';

export async function getStaticPaths() {
  const entries = await getCollection('directives');
  return entries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const base = import.meta.env.BASE_URL;
const siteOrigin = 'https://mih4ajlo.github.io';
const pageUrl = `${siteOrigin}${base}directives/${entry.slug}`;

const allEntries = await getCollection('directives');
const byDirective = new Map(
  allEntries
    .filter(e => e.data.directive)
    .map(e => [e.data.directive!.trim(), e])
);
const relatedEntries = (entry.data.related ?? [])
  .map(ref => byDirective.get(ref.trim()))
  .filter((e): e is NonNullable<typeof e> => e !== undefined && e.slug !== entry.slug);

const questionsData = await import('../../../data/questions.json');
const entryQuestions = (questionsData.default as QuestionEntry[]).filter(q => q.slug === entry.slug);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: entry.data.title,
  description: entry.data.summary,
  url: pageUrl,
  datePublished: `${entry.data.year}-01-01`,
  keywords: entry.data.tags.join(', '),
  publisher: { '@type': 'Organization', name: 'Why Is That, EU?' },
};
---
<Layout title={entry.data.title} description={entry.data.summary} canonicalPath={`directives/${entry.slug}`}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <style>
    .qa-block { margin: 2rem 0; padding: 1.1rem 1.4rem; background: var(--tag-bg); border-radius: var(--radius); }
    .qa-block-label { font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); margin-bottom: 0.7rem; }
    .qa-list { list-style: none; display: flex; flex-direction: column; gap: 0.4rem; }
    .qa-list a { font-size: 0.88rem; color: var(--accent); line-height: 1.4; }
    .qa-list a:hover { text-decoration: underline; }

    .entry-header { margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border); }
    .entry-title { font-size: 1.75rem; font-weight: 700; letter-spacing: -0.02em; line-height: 1.2; margin-bottom: 0.75rem; }
    .entry-meta { display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; margin-bottom: 0.75rem; }
    .category-badge { font-size: 0.78rem; padding: 0.25rem 0.65rem; border-radius: 4px; background: var(--accent-soft); color: var(--accent); font-weight: 500; }
    .category-badge:hover { text-decoration: underline; }
    .directive-ref { font-size: 0.78rem; color: var(--muted); font-family: monospace; background: var(--tag-bg); padding: 0.2rem 0.55rem; border-radius: 4px; }
    .tag { font-size: 0.72rem; padding: 0.2rem 0.55rem; border-radius: 4px; background: var(--tag-bg); color: var(--muted); }
    .tag:hover { background: var(--border); }
    .year { font-size: 0.78rem; color: var(--muted); }
    .status-badge { font-size: 0.72rem; font-weight: 500; padding: 0.2rem 0.6rem; border-radius: 999px; }
    .status-in-force  { background: #dcfce7; color: #166534; }
    .status-proposed  { background: #fef9c3; color: #854d0e; }
    .status-repealed  { background: #f1f5f9; color: #64748b; }
    .status-withdrawn { background: #fee2e2; color: #991b1b; }
    .llm-badge { font-size: 0.68rem; font-weight: 500; padding: 0.15rem 0.5rem; border-radius: 999px; background: #f0f0f0; color: #555; border: 1px solid #ddd; }

    .entry-summary { font-size: 1rem; color: var(--muted); max-width: 60ch; line-height: 1.5; }

    .content { font-size: 0.95rem; line-height: 1.8; }
    .content :global(h2) { font-size: 1.2rem; font-weight: 700; margin: 2rem 0 0.75rem; padding-top: 1.5rem; border-top: 1px solid var(--border); color: var(--text); }
    .content :global(h3) { font-size: 1rem; font-weight: 600; margin: 1.5rem 0 0.5rem; color: var(--text); }
    .content :global(p) { margin-bottom: 1rem; }
    .content :global(ul), .content :global(ol) { margin: 0 0 1rem 1.5rem; }
    .content :global(li) { margin-bottom: 0.35rem; }
    .content :global(a) { color: var(--accent); }
    .content :global(strong) { font-weight: 600; color: var(--text); }
    .content :global(blockquote) { border-left: 3px solid var(--border); padding-left: 1rem; color: var(--muted); margin: 1rem 0; }
    .content :global(code) { font-size: 0.85em; background: var(--tag-bg); padding: 0.1em 0.35em; border-radius: 3px; }

    .related { margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--border); }
    .related h2 { font-size: 1rem; font-weight: 700; margin-bottom: 1rem; color: var(--text); }
    .related-list { display: grid; gap: 0.6rem; }
    .related-card { display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 0.85rem 1.1rem; color: inherit; transition: border-color 0.15s; }
    .related-card:hover { border-color: var(--accent); text-decoration: none; }
    .related-card-title { font-size: 0.9rem; font-weight: 600; color: var(--text); line-height: 1.3; }
    .related-card-summary { font-size: 0.8rem; color: var(--muted); margin-top: 0.25rem; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; }
    .related-card-ref { font-size: 0.72rem; color: var(--muted); font-family: monospace; white-space: nowrap; padding-top: 0.1rem; }
  </style>

  <Breadcrumb crumbs={[
    {label: 'Home', href: base},
    {label: entry.data.category, href: `${base}categories/${categorySlug(entry.data.category)}`},
    {label: entry.data.title.length > 60 ? entry.data.title.slice(0, 57) + '…' : entry.data.title},
  ]} />

  <div class="entry-header">
    <h1 class="entry-title">{entry.data.title}</h1>
    <div class="entry-meta">
      <a href={`${base}categories/${categorySlug(entry.data.category)}`} class="category-badge" data-pagefind-meta="category">{entry.data.category}</a>
      {entry.data.directive && <span class="directive-ref" data-pagefind-meta="directive">{entry.data.directive}</span>}
      <span class="year">{entry.data.year}</span>
      <span class={`status-badge status-${entry.data.status}`}>
        {STATUS_LABEL[entry.data.status] ?? entry.data.status}
      </span>
      {entry.data.tags.map(tag => (
        <a href={`${base}tags/${tag}`} class="tag">{tag}</a>
      ))}
      {entry.data.llm && (
        <span class="llm-badge" title={`Drafted with ${entry.data.llm}`}>
          {llmLabel(entry.data.llm)}
        </span>
      )}
    </div>
    <p class="entry-summary">{entry.data.summary}</p>
  </div>

  {entryQuestions.length > 0 && (
    <div class="qa-block">
      <p class="qa-block-label">Key questions</p>
      <ul class="qa-list">
        {entryQuestions.map(q => (
          <li><a href={`${base}questions/${q.id}`}>{q.question}</a></li>
        ))}
      </ul>
    </div>
  )}

  <div class="content" data-pagefind-body>
    <Content />
  </div>

  {relatedEntries.length > 0 && (
    <div class="related">
      <h2>Related legislation</h2>
      <div class="related-list">
        {relatedEntries.map(rel => (
          <a href={`${base}directives/${rel.slug}`} class="related-card">
            <div>
              <div class="related-card-title">{rel.data.title}</div>
              <div class="related-card-summary">{rel.data.summary}</div>
            </div>
            {rel.data.directive && <span class="related-card-ref">{rel.data.directive}</span>}
          </a>
        ))}
      </div>
    </div>
  )}
</Layout>
