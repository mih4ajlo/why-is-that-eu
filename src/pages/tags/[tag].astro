---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { llmLabel, categorySlug, STATUS_LABEL } from '../../lib/format';

export async function getStaticPaths() {
  const all = await getCollection('directives');
  const tags = new Set(all.flatMap(e => e.data.tags));
  return [...tags].map(tag => ({
    params: { tag },
    props: {
      tag,
      entries: all
        .filter(e => e.data.tags.includes(tag))
        .sort((a, b) => b.data.year - a.data.year),
    },
  }));
}

const { tag, entries } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<Layout title={`Tag: ${tag}`} description={`EU laws tagged "${tag}" — ${entries.length} entries`} canonicalPath={`tags/${tag}`}>
  <style>
    .page-header { margin-bottom: 2rem; }
    .page-header h1 { font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 0.4rem; }
    .page-header p { color: var(--muted); font-size: 0.9rem; }
    .entries { display: grid; gap: 1rem; }
    .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.25rem 1.5rem; transition: border-color 0.15s; }
    .card:hover { border-color: var(--accent); }
    .card-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; margin-bottom: 0.4rem; }
    .card-title { font-size: 1rem; font-weight: 600; color: var(--accent); line-height: 1.35; }
    .card-title:hover { text-decoration: underline; }
    .card-year { font-size: 0.78rem; color: var(--muted); white-space: nowrap; padding-top: 0.15rem; }
    .card-summary { font-size: 0.875rem; color: var(--muted); margin-bottom: 0.75rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .card-meta { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
    .category-badge { font-size: 0.72rem; padding: 0.2rem 0.6rem; border-radius: 4px; background: var(--accent-soft); color: var(--accent); font-weight: 500; }
    .category-badge:hover { text-decoration: underline; }
    .tag { font-size: 0.72rem; padding: 0.2rem 0.55rem; border-radius: 4px; background: var(--tag-bg); color: var(--muted); }
    .tag:hover { background: var(--border); }
    .tag.current { background: var(--accent); color: #fff; }
    .directive-ref { font-size: 0.72rem; color: var(--muted); font-family: monospace; }
    .status-badge { font-size: 0.68rem; font-weight: 500; padding: 0.15rem 0.5rem; border-radius: 999px; }
    .status-in-force  { background: #dcfce7; color: #166534; }
    .status-proposed  { background: #fef9c3; color: #854d0e; }
    .status-repealed  { background: #f1f5f9; color: #64748b; }
    .status-withdrawn { background: #fee2e2; color: #991b1b; }
    .llm-badge { font-size: 0.68rem; font-weight: 500; padding: 0.15rem 0.5rem; border-radius: 999px; background: #f0f0f0; color: #555; border: 1px solid #ddd; }
  </style>

  <Breadcrumb crumbs={[{label: 'Home', href: base}, {label: `#${tag}`}]} />

  <div class="page-header">
    <h1>#{tag}</h1>
    <p>{entries.length} {entries.length === 1 ? 'entry' : 'entries'}</p>
  </div>

  <div class="entries">
    {entries.map(entry => (
      <div class="card">
        <div class="card-header">
          <a href={`${base}directives/${entry.slug}`} class="card-title">{entry.data.title}</a>
          <span class="card-year">{entry.data.year}</span>
        </div>
        <p class="card-summary">{entry.data.summary}</p>
        <div class="card-meta">
          <a href={`${base}categories/${categorySlug(entry.data.category)}`} class="category-badge">{entry.data.category}</a>
          {entry.data.directive && <span class="directive-ref">{entry.data.directive}</span>}
          {entry.data.tags.slice(0, 4).map(t => (
            t === tag
              ? <span class="tag current">{t}</span>
              : <a href={`${base}tags/${t}`} class="tag">{t}</a>
          ))}
          {entry.data.status !== 'in-force' && (
            <span class={`status-badge status-${entry.data.status}`}>
              {STATUS_LABEL[entry.data.status] ?? entry.data.status}
            </span>
          )}
          {entry.data.llm && (
            <span class="llm-badge" title={entry.data.llm}>{llmLabel(entry.data.llm)}</span>
          )}
        </div>
      </div>
    ))}
  </div>
</Layout>
