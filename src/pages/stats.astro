---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { categorySlug } from '../lib/format';
import type { QuestionEntry } from '../../scripts/extract-questions';

const entries = await getCollection('directives');
const questionsData = await import('../../data/questions.json');
const questions = questionsData.default as QuestionEntry[];

const base = import.meta.env.BASE_URL;

// By category
const byCat = new Map<string, number>();
for (const e of entries) {
  byCat.set(e.data.category, (byCat.get(e.data.category) ?? 0) + 1);
}
const catRows = [...byCat.entries()].sort((a, b) => b[1] - a[1]);
const maxCat = Math.max(...catRows.map(r => r[1]));

// By year
const byYear = new Map<number, number>();
for (const e of entries) {
  byYear.set(e.data.year, (byYear.get(e.data.year) ?? 0) + 1);
}
const yearRows = [...byYear.entries()].sort((a, b) => a[0] - b[0]);
const maxYear = Math.max(...yearRows.map(r => r[1]));

// Questions per category
const qByCat = new Map<string, number>();
for (const q of questions) {
  qByCat.set(q.category, (qByCat.get(q.category) ?? 0) + 1);
}
const qCatRows = [...qByCat.entries()].sort((a, b) => b[1] - a[1]);
const maxQCat = Math.max(...qCatRows.map(r => r[1]));

// Status breakdown
const statuses = { 'in-force': 0, proposed: 0, repealed: 0, withdrawn: 0 };
for (const e of entries) {
  const s = e.data.status as keyof typeof statuses;
  if (s in statuses) statuses[s]++;
}
---
<Layout title="Stats" description={`${entries.length} EU laws explained across ${catRows.length} categories.`} canonicalPath="stats">
  <style>
    h1 { font-size: 1.75rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 2rem; }

    .kpi-row { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
    .kpi {
      flex: 1; min-width: 120px;
      background: var(--surface); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 1rem 1.25rem;
    }
    .kpi-value { font-size: 2rem; font-weight: 700; letter-spacing: -0.03em; color: var(--text); line-height: 1; margin-bottom: 0.3rem; }
    .kpi-label { font-size: 0.78rem; color: var(--muted); }

    .section { margin-bottom: 2.5rem; }
    .section h2 { font-size: 1rem; font-weight: 700; margin-bottom: 1.1rem; color: var(--text); }

    .bar-row {
      display: grid;
      grid-template-columns: 11rem 1fr 2.5rem;
      align-items: center;
      gap: 0.6rem;
      margin-bottom: 0.45rem;
    }
    .bar-label { font-size: 0.82rem; color: var(--text); text-align: right; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .bar-label a { color: inherit; }
    .bar-label a:hover { color: var(--accent); text-decoration: underline; }
    .bar-track { background: var(--tag-bg); border-radius: 3px; height: 10px; overflow: hidden; }
    .bar-fill { height: 100%; background: var(--accent); border-radius: 3px; }
    .bar-count { font-size: 0.78rem; color: var(--muted); }
    .bar-avg { font-size: 0.72rem; color: var(--muted); opacity: 0.7; }

    .year-row {
      display: grid;
      grid-template-columns: 3rem 1fr 2rem;
      align-items: center;
      gap: 0.6rem;
      margin-bottom: 0.45rem;
    }
    .year-label { font-size: 0.78rem; color: var(--muted); text-align: right; font-variant-numeric: tabular-nums; }

    .status-row { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 0.5rem; }
    .status-chip { font-size: 0.8rem; padding: 0.3rem 0.75rem; border-radius: 999px; }
    .status-in-force  { background: #dcfce7; color: #166534; }
    .status-proposed  { background: #fef9c3; color: #854d0e; }
    .status-repealed  { background: #f1f5f9; color: #64748b; }
    .status-withdrawn { background: #fee2e2; color: #991b1b; }
  </style>

  <Breadcrumb crumbs={[{label: 'Home', href: base}, {label: 'Stats'}]} />

  <h1>Stats</h1>

  <div class="kpi-row">
    <div class="kpi">
      <div class="kpi-value">{entries.length}</div>
      <div class="kpi-label">laws explained</div>
    </div>
    <div class="kpi">
      <div class="kpi-value">{questions.length}</div>
      <div class="kpi-label">questions answered</div>
    </div>
    <div class="kpi">
      <div class="kpi-value">{catRows.length}</div>
      <div class="kpi-label">categories</div>
    </div>
    <div class="kpi">
      <div class="kpi-value">{yearRows.length}</div>
      <div class="kpi-label">years covered</div>
    </div>
  </div>

  <div class="section">
    <h2>Entries by category</h2>
    {catRows.map(([cat, count]) => (
      <div class="bar-row">
        <span class="bar-label">
          <a href={`${base}categories/${categorySlug(cat)}`}>{cat}</a>
        </span>
        <div class="bar-track">
          <div class="bar-fill" style={`width: ${(count / maxCat * 100).toFixed(1)}%`}></div>
        </div>
        <span class="bar-count">{count}</span>
      </div>
    ))}
  </div>

  <div class="section">
    <h2>Questions by category</h2>
    {qCatRows.map(([cat, count]) => (
      <div class="bar-row">
        <span class="bar-label">
          <a href={`${base}categories/${categorySlug(cat)}`}>{cat}</a>
        </span>
        <div class="bar-track">
          <div class="bar-fill" style={`width: ${(count / maxQCat * 100).toFixed(1)}%`}></div>
        </div>
        <span class="bar-count">{count}</span>
      </div>
    ))}
  </div>

  <div class="section">
    <h2>Entries by year</h2>
    {yearRows.map(([year, count]) => (
      <div class="year-row">
        <span class="year-label">{year}</span>
        <div class="bar-track">
          <div class="bar-fill" style={`width: ${(count / maxYear * 100).toFixed(1)}%`}></div>
        </div>
        <span class="bar-count">{count}</span>
      </div>
    ))}
  </div>

  <div class="section">
    <h2>Status breakdown</h2>
    <div class="status-row">
      <span class="status-chip status-in-force">{statuses['in-force']} in force</span>
      {statuses.proposed > 0 && <span class="status-chip status-proposed">{statuses.proposed} proposed</span>}
      {statuses.repealed > 0 && <span class="status-chip status-repealed">{statuses.repealed} repealed</span>}
      {statuses.withdrawn > 0 && <span class="status-chip status-withdrawn">{statuses.withdrawn} withdrawn</span>}
    </div>
  </div>
</Layout>
