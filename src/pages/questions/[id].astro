---
import Layout from '../../layouts/Layout.astro';
import { categorySlug } from '../../lib/format';
import type { QuestionEntry } from '../../../scripts/extract-questions';

const questionsData = await import('../../../data/questions.json');
const questions = questionsData.default as QuestionEntry[];

export async function getStaticPaths() {
  const data = await import('../../../data/questions.json');
  const qs = data.default as QuestionEntry[];
  return qs.map(q => ({ params: { id: q.id }, props: { q } }));
}

const { q } = Astro.props;
const base = import.meta.env.BASE_URL;
const siteOrigin = 'https://mih4ajlo.github.io';
const pageUrl = `${siteOrigin}${base}questions/${q.id}`;

const siblings = questions.filter(x => x.slug === q.slug && x.id !== q.id);

function renderAnswer(md: string): string {
  return md
    .split(/\n{2,}/)
    .map(para => para.trim())
    .filter(Boolean)
    .map(para => {
      const html = para
        .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
        .replace(/\*([^*]+)\*/g, '<em>$1</em>')
        .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');
      return `<p>${html}</p>`;
    })
    .join('');
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [{
    '@type': 'Question',
    name: q.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: q.answer.replace(/\*\*([^*]+)\*\*/g, '$1').replace(/\[([^\]]+)\]\([^)]+\)/g, '$1'),
    },
  }],
};
---
<Layout
  title={q.question}
  description={q.answer.slice(0, 160).replace(/\*\*([^*]+)\*\*/g, '$1') + '…'}
  canonicalPath={`questions/${q.id}`}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <style>
    .back { font-size: 0.85rem; color: var(--muted); margin-bottom: 2rem; display: inline-flex; align-items: center; gap: 0.3rem; }
    .back:hover { color: var(--accent); }

    .q-header { margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border); }
    .q-label { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); margin-bottom: 0.75rem; }
    h1 { font-size: 1.6rem; font-weight: 700; letter-spacing: -0.02em; line-height: 1.25; margin-bottom: 1rem; }
    .q-meta { display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; }
    .category-badge { font-size: 0.75rem; padding: 0.22rem 0.65rem; border-radius: 4px; background: var(--accent-soft); color: var(--accent); font-weight: 500; }
    .category-badge:hover { text-decoration: underline; }
    .year { font-size: 0.75rem; color: var(--muted); }

    .answer { font-size: 0.975rem; line-height: 1.8; margin-bottom: 2.5rem; }
    .answer :global(p) { margin-bottom: 1rem; }
    .answer :global(strong) { font-weight: 600; color: var(--text); }
    .answer :global(a) { color: var(--accent); }
    .answer :global(em) { font-style: italic; }

    .source {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1rem 1.25rem;
      margin-bottom: 2.5rem;
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
      transition: border-color 0.15s;
    }
    .source:hover { border-color: var(--accent); text-decoration: none; }
    .source-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--muted); margin-bottom: 0.3rem; }
    .source-title { font-size: 0.9rem; font-weight: 600; color: var(--text); line-height: 1.3; }
    .source-ref { font-size: 0.72rem; color: var(--muted); font-family: monospace; white-space: nowrap; padding-top: 0.1rem; }

    .siblings { border-top: 1px solid var(--border); padding-top: 1.5rem; }
    .siblings h2 { font-size: 0.9rem; font-weight: 700; margin-bottom: 0.9rem; color: var(--text); }
    .sibling-list { display: grid; gap: 0.5rem; }
    .sibling { font-size: 0.875rem; color: var(--accent); padding: 0.5rem 0; border-bottom: 1px solid var(--border); display: block; }
    .sibling:last-child { border-bottom: none; }
    .sibling:hover { text-decoration: underline; }
  </style>

  <a href={`${base}questions`} class="back">← All questions</a>

  <div class="q-header">
    <p class="q-label">Question</p>
    <h1>{q.question}</h1>
    <div class="q-meta">
      <a href={`${base}categories/${categorySlug(q.category)}`} class="category-badge">{q.category}</a>
      <span class="year">{q.year}</span>
    </div>
  </div>

  <div class="answer" set:html={renderAnswer(q.answer)} />

  <a href={`${base}directives/${q.slug}`} class="source">
    <div>
      <p class="source-label">Answered by</p>
      <p class="source-title">{q.title}</p>
    </div>
    {q.directive && <span class="source-ref">{q.directive}</span>}
  </a>

  {siblings.length > 0 && (
    <div class="siblings">
      <h2>More questions about this regulation</h2>
      <div class="sibling-list">
        {siblings.map(s => (
          <a href={`${base}questions/${s.id}`} class="sibling">{s.question}</a>
        ))}
      </div>
    </div>
  )}
</Layout>
