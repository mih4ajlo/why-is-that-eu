---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allEntries = await getCollection('directives');
const sorted = allEntries.sort((a, b) => b.data.year - a.data.year);

const categories = [...new Set(allEntries.map(e => e.data.category))].sort();
const base = import.meta.env.BASE_URL;
---
<Layout title="Browse EU Directives">
  <style>
    .intro {
      margin-bottom: 2rem;
    }
    .intro h1 {
      font-size: 1.75rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 0.5rem;
    }
    .intro p {
      color: var(--muted);
      max-width: 52ch;
    }

    .filter-bar {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin-bottom: 1.75rem;
    }
    .filter-btn {
      padding: 0.35rem 0.85rem;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--muted);
      font-size: 0.82rem;
      cursor: pointer;
      transition: all 0.15s;
      font-family: inherit;
    }
    .filter-btn:hover, .filter-btn.active {
      background: var(--accent);
      border-color: var(--accent);
      color: #fff;
    }

    .entries {
      display: grid;
      gap: 1rem;
    }

    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.25rem 1.5rem;
      transition: border-color 0.15s;
    }
    .card:hover { border-color: var(--accent); }
    .card a { color: inherit; display: block; }
    .card a:hover { text-decoration: none; }

    .card-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 0.4rem;
    }
    .card-title {
      font-size: 1rem;
      font-weight: 600;
      color: var(--text);
    }
    .card-year {
      font-size: 0.78rem;
      color: var(--muted);
      white-space: nowrap;
      padding-top: 0.15rem;
    }
    .card-summary {
      font-size: 0.875rem;
      color: var(--muted);
      margin-bottom: 0.75rem;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .card-meta {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex-wrap: wrap;
    }
    .category-badge {
      font-size: 0.72rem;
      padding: 0.2rem 0.6rem;
      border-radius: 4px;
      background: var(--accent-soft);
      color: var(--accent);
      font-weight: 500;
    }
    .tag {
      font-size: 0.72rem;
      padding: 0.2rem 0.55rem;
      border-radius: 4px;
      background: var(--tag-bg);
      color: var(--muted);
    }
    .directive-ref {
      font-size: 0.72rem;
      color: var(--muted);
      font-family: monospace;
    }

    .empty {
      text-align: center;
      padding: 3rem 0;
      color: var(--muted);
    }
  </style>

  <div class="intro">
    <h1>EU Directives &amp; Standards</h1>
    <p>Explore the history and reasoning behind EU legislation — why USB-C became mandatory, why phone chargers are no longer bundled, and more.</p>
  </div>

  <div class="filter-bar">
    <button class="filter-btn active" data-category="all">All</button>
    {categories.map(cat => (
      <button class="filter-btn" data-category={cat}>{cat}</button>
    ))}
  </div>

  <div class="entries" id="entries">
    {sorted.length === 0 && (
      <div class="empty">
        <p>No entries yet. Run <code>npm run draft "topic"</code> to generate your first entry.</p>
      </div>
    )}
    {sorted.map(entry => (
      <div class="card" data-category={entry.data.category}>
        <a href={`${base}directives/${entry.slug}`}>
          <div class="card-header">
            <span class="card-title">{entry.data.title}</span>
            <span class="card-year">{entry.data.year}</span>
          </div>
          <p class="card-summary">{entry.data.summary}</p>
          <div class="card-meta">
            <span class="category-badge">{entry.data.category}</span>
            {entry.data.directive && <span class="directive-ref">{entry.data.directive}</span>}
            {entry.data.tags.slice(0, 3).map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </a>
      </div>
    ))}
  </div>

  <script>
    const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const cards = document.querySelectorAll<HTMLElement>('.card[data-category]');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const cat = btn.dataset.category!;
        buttons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        cards.forEach(card => {
          const show = cat === 'all' || card.dataset.category === cat;
          card.style.display = show ? '' : 'none';
        });
      });
    });
  </script>
</Layout>
