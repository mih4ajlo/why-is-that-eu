---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---
<Layout title="Search" description="Search EU directives and standards">
  <style>
    .search-header {
      margin-bottom: 2rem;
    }
    .search-header h1 {
      font-size: 1.5rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 0.5rem;
    }
    .search-box {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 2rem;
    }
    #search-input {
      flex: 1;
      padding: 0.6rem 0.9rem;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: var(--surface);
      font-size: 1rem;
      color: var(--text);
      outline: none;
    }
    #search-input:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 15%, transparent);
    }
    #results {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .result-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.1rem 1.25rem;
    }
    .result-card a {
      font-weight: 600;
      font-size: 1rem;
      color: var(--text);
    }
    .result-card a:hover { color: var(--accent); text-decoration: none; }
    .result-excerpt {
      font-size: 0.85rem;
      color: var(--muted);
      margin-top: 0.35rem;
      line-height: 1.5;
    }
    .result-excerpt mark {
      background: color-mix(in srgb, var(--accent) 15%, transparent);
      color: var(--text);
      border-radius: 2px;
      padding: 0 2px;
    }
    .result-meta {
      font-size: 0.75rem;
      color: var(--muted);
      margin-top: 0.4rem;
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }
    .no-results {
      color: var(--muted);
      font-size: 0.9rem;
    }
    .hint {
      color: var(--muted);
      font-size: 0.875rem;
    }
  </style>

  <div class="search-header">
    <h1>Search</h1>
  </div>

  <div class="search-box">
    <input
      id="search-input"
      type="search"
      placeholder="e.g. USB-C, charger, packaging..."
      autofocus
    />
  </div>

  <div id="results">
    <p class="hint">Start typing to search across all EU directives.</p>
  </div>
</Layout>

<script define:vars={{ base }}>
  let pagefind;

  async function loadPagefind() {
    if (pagefind) return pagefind;
    try {
      pagefind = await import(`${base}pagefind/pagefind.js`);
      await pagefind.init();
    } catch {
      pagefind = null;
    }
    return pagefind;
  }

  const input = document.getElementById('search-input');
  const results = document.getElementById('results');
  let debounceTimer;

  input.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => search(input.value.trim()), 200);
  });

  async function search(query) {
    if (!query) {
      results.innerHTML = '<p class="hint">Start typing to search across all EU directives.</p>';
      return;
    }

    const pf = await loadPagefind();
    if (!pf) {
      results.innerHTML = '<p class="no-results">Search index not available. Run <code>npm run build</code> first.</p>';
      return;
    }

    const response = await pf.search(query);

    if (response.results.length === 0) {
      results.innerHTML = '<p class="no-results">No results found.</p>';
      return;
    }

    const cards = await Promise.all(
      response.results.slice(0, 20).map(async (r) => {
        const data = await r.data();
        const category = data.meta?.category ?? '';
        const directive = data.meta?.directive ?? '';
        return `
          <div class="result-card">
            <a href="${data.url}">${data.meta?.title ?? data.url}</a>
            <div class="result-excerpt">${data.excerpt}</div>
            <div class="result-meta">
              ${category ? `<span>${category}</span>` : ''}
              ${directive ? `<span>${directive}</span>` : ''}
            </div>
          </div>`;
      })
    );

    results.innerHTML = cards.join('');
  }

  // Run search if query is in URL
  const params = new URLSearchParams(window.location.search);
  const q = params.get('q');
  if (q) {
    input.value = q;
    search(q);
  }
</script>
