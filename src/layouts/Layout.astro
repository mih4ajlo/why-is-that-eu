---
interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
}
const {
  title,
  description = 'A minimalist knowledge base explaining the why behind EU directives and standards.',
  canonicalPath,
} = Astro.props;
const base = import.meta.env.BASE_URL;
const siteOrigin = 'https://mih4ajlo.github.io';
const canonicalUrl = canonicalPath
  ? `${siteOrigin}${base}${canonicalPath}`.replace(/([^:])\/\/+/g, '$1/')
  : `${siteOrigin}${base}`;
const ogTitle = `${title} — Why Is That, EU?`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{ogTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={canonicalPath ? 'article' : 'website'} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Why Is That, EU?" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />

    <!-- Anti-FOUC: apply saved theme before first paint -->
    <script is:inline>
      (function() {
        try {
          var t = localStorage.getItem('theme');
          if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.dataset.theme = 'dark';
          }
        } catch(e) {}
      })();
    </script>

    <slot name="head" />

    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg: #f9f7f4;
        --surface: #ffffff;
        --border: #e2ddd6;
        --text: #1a1814;
        --muted: #6b6560;
        --accent: #2563eb;
        --accent-soft: #eff6ff;
        --tag-bg: #f0ece6;
        --radius: 8px;
        --max-w: 860px;
        font-size: 16px;
      }

      :global([data-theme="dark"]) {
        --bg: #111110;
        --surface: #1c1b1a;
        --border: #2e2c2a;
        --text: #e8e4df;
        --muted: #8a8480;
        --accent: #60a5fa;
        --accent-soft: #1e3a5f;
        --tag-bg: #262422;
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        line-height: 1.6;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }

      header {
        border-bottom: 1px solid var(--border);
        background: var(--surface);
      }
      .header-inner {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 1.25rem 1.5rem;
        display: flex;
        align-items: baseline;
        gap: 1rem;
        flex-wrap: wrap;
      }
      .site-name {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--text);
        letter-spacing: -0.01em;
      }
      .site-name a { color: inherit; }
      .site-tagline {
        font-size: 0.85rem;
        color: var(--muted);
        flex: 1;
      }
      .header-nav {
        font-size: 0.85rem;
        margin-left: auto;
        display: flex;
        gap: 1rem;
        align-items: center;
      }
      .header-nav a { color: var(--muted); }
      .header-nav a:hover { color: var(--accent); }

      .theme-toggle {
        background: none;
        border: 1px solid var(--border);
        border-radius: 999px;
        padding: 0.2rem 0.6rem;
        font-size: 0.8rem;
        color: var(--muted);
        cursor: pointer;
        font-family: inherit;
        transition: border-color 0.15s, color 0.15s;
      }
      .theme-toggle:hover { border-color: var(--accent); color: var(--accent); }

      main {
        flex: 1;
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 2rem 1.5rem;
        width: 100%;
      }

      footer {
        border-top: 1px solid var(--border);
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 1.5rem;
        font-size: 0.8rem;
        color: var(--muted);
        width: 100%;
      }

      :global([data-theme="dark"]) :global(.status-in-force)  { background: #14532d; color: #86efac; }
      :global([data-theme="dark"]) :global(.status-proposed)  { background: #713f12; color: #fde68a; }
      :global([data-theme="dark"]) :global(.status-repealed)  { background: #1e293b; color: #94a3b8; }
      :global([data-theme="dark"]) :global(.status-withdrawn) { background: #7f1d1d; color: #fca5a5; }
      :global([data-theme="dark"]) :global(.llm-badge) { background: #262422; color: #8a8480; border-color: #2e2c2a; }
    </style>
  </head>
  <body>
    <header>
      <div class="header-inner">
        <div class="site-name"><a href={base}>Why Is That, EU?</a></div>
        <div class="site-tagline">The history and reasoning behind EU legislation</div>
        <nav class="header-nav">
          <a href={`${base}questions`}>Questions</a>
          <a href={`${base}search`}>Search</a>
          <a href={`${base}about`}>About</a>
          <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode">◐</button>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      AI-assisted knowledge base. Not legal advice. Always verify with official EU sources.
    </footer>
    <script>
      const btn = document.getElementById('theme-toggle');
      btn?.addEventListener('click', () => {
        const isDark = document.documentElement.dataset.theme === 'dark';
        document.documentElement.dataset.theme = isDark ? '' : 'dark';
        try { localStorage.setItem('theme', isDark ? 'light' : 'dark'); } catch(e) {}
      });
    </script>
  </body>
</html>
